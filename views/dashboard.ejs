<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<main class="flex-1 p-4 md:p-10">
    <header class="mb-8">
        <h1 class="text-2xl md:text-3xl font-black text-gray-800">Selamat Datang, <%= user.username %>! 👋</h1>
        <p class="text-gray-500">Semangat kerjanya, jangan lupa cek antrean hari ini.</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        <div onclick="window.location.href='/order'" class="bg-blue-600 p-6 rounded-3xl text-white shadow-lg cursor-pointer transform transition hover:scale-105 active:scale-95">
            <div class="text-4xl mb-4">👟</div>
            <h3 class="text-xl font-bold">Buat Order Baru</h3>
            <p class="text-blue-100 text-sm mt-1">Input cucian masuk sekarang.</p>
        </div>

        <div onclick="window.location.href='/list-order'" class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm cursor-pointer transform transition hover:scale-105 active:scale-95">
            <div class="text-4xl mb-4">📋</div>
            <h3 class="text-xl font-bold text-gray-800">List Antrean</h3>
            <p class="text-gray-500 text-sm mt-1">Cek status pengerjaan sepatu.</p>
        </div>

        <div onclick="window.location.href='/pelanggan'" class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm cursor-pointer transform transition hover:scale-105 active:scale-95">
            <div class="text-4xl mb-4">👥</div>
            <h3 class="text-xl font-bold text-gray-800">Data Pelanggan</h3>
            <p class="text-gray-500 text-sm mt-1">Manajemen member dan riwayat.</p>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
