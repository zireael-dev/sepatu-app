<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<main class="flex-1 p-4 md:p-8 bg-gray-50 overflow-y-auto">
    <div class="max-w-6xl mx-auto">
        <h1 class="text-2xl font-black text-gray-800 mb-6 uppercase tracking-tight">Form Order Baru</h1>
        
        <form action="/order/tambah" method="POST" class="flex flex-col lg:flex-row gap-6">
            
            <div class="flex-1 space-y-6">
                <div class="bg-white p-5 rounded-2xl shadow-sm border border-gray-100">
                    <label class="block text-sm font-bold text-gray-700 mb-3">Pilih Pelanggan</label>
                    <select name="pelanggan_id" class="w-full p-3 rounded-xl border-2 border-gray-100 focus:border-blue-500 outline-none transition appearance-none">
                        <% pelanggan.forEach(p => { %>
                            <option value="<%= p.id %>"><%= p.nama %> (<%= p.whatsapp %>)</option>
                        <% }) %>
                    </select>
                </div>

                <div class="bg-white p-5 rounded-2xl shadow-sm border border-gray-100">
                    <h3 class="font-bold text-gray-800 mb-4 border-b pb-2">Detail Cucian</h3>
                    <div id="service-container" class="space-y-4">
                        <div class="p-4 bg-gray-50 rounded-xl border border-dashed border-gray-200">
                            <input type="text" name="services[0][0][nama_sepatu]" placeholder="Merk/Nama Sepatu" class="w-full p-2 mb-3 rounded-lg border focus:ring-2 focus:ring-blue-500 outline-none" required>
                            <select name="services[0][0][layanan_id]" class="w-full p-2 rounded-lg border focus:ring-2 focus:ring-blue-500 outline-none">
                                <% layanan.forEach(l => { %>
                                    <option value="<%= l.id %>" data-harga="<%= l.harga %>"><%= l.nama %> - Rp <%= l.harga %></option>
                                <% }) %>
                            </select>
                            <input type="hidden" name="services[0][0][harga_satuan]" value="<%= layanan[0]?.harga || 0 %>">
                        </div>
                    </div>
                    <button type="button" onclick="addServiceRow()" class="w-full mt-4 py-3 border-2 border-dashed border-blue-200 text-blue-600 font-bold rounded-xl hover:bg-blue-50 transition">+ Tambah Sepatu</button>
                </div>
            </div>

            <div class="lg:w-80">
                <div class="bg-slate-900 text-white p-6 rounded-3xl shadow-xl sticky top-8">
                    <h3 class="text-lg font-bold mb-4 border-b border-slate-700 pb-2">Ringkasan Nota</h3>
                    <div class="flex justify-between items-center mb-6">
                        <span class="text-slate-400">Total Tagihan</span>
                        <span class="text-2xl font-black text-blue-400" id="display-total">Rp 0</span>
                    </div>
                    <input type="hidden" name="total_harga" id="input-total" value="0">
                    <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-black py-4 rounded-2xl transition shadow-lg shadow-blue-900/50">PROSES PESANAN</button>
                    <p class="text-[10px] text-slate-500 text-center mt-4">Nota digital & WhatsApp akan dikirim otomatis.</p>
                </div>
            </div>

        </form>
    </div>
</main>

<script>
    // Pastikan fungsi hitung total & tambah baris sudah menyesuaikan dengan id baru
    function calculateTotal() {
        let total = 0;
        document.querySelectorAll('select[name*="[layanan_id]"]').forEach(select => {
            const selectedOption = select.options[select.selectedIndex];
            const harga = parseInt(selectedOption.getAttribute('data-harga')) || 0;
            total += harga;
            // Update hidden input harga_satuan di baris yang sama
            select.closest('div').querySelector('input[name*="[harga_satuan]"]').value = harga;
        });
        document.getElementById('display-total').innerText = 'Rp ' + total.toLocaleString('id-ID');
        document.getElementById('input-total').value = total;
    }

    let rowIndex = 1;
    function addServiceRow() {
        const container = document.getElementById('service-container');
        const newRow = `
            <div class="p-4 bg-gray-50 rounded-xl border border-dashed border-gray-200 relative group">
                <button type="button" onclick="this.parentElement.remove(); calculateTotal();" class="absolute -top-2 -right-2 bg-red-500 text-white w-6 h-6 rounded-full text-xs">✕</button>
                <input type="text" name="services[${rowIndex}][0][nama_sepatu]" placeholder="Merk/Nama Sepatu" class="w-full p-2 mb-3 rounded-lg border focus:ring-2 focus:ring-blue-500 outline-none" required>
                <select name="services[${rowIndex}][0][layanan_id]" onchange="calculateTotal()" class="w-full p-2 rounded-lg border focus:ring-2 focus:ring-blue-500 outline-none">
                    <% layanan.forEach(l => { %>
                        <option value="<%= l.id %>" data-harga="<%= l.harga %>"><%= l.nama %> - Rp <%= l.harga %></option>
                    <% }) %>
                </select>
                <input type="hidden" name="services[${rowIndex}][0][harga_satuan]" value="<%= layanan[0]?.harga || 0 %>">
            </div>
        `;
        container.insertAdjacentHTML('beforeend', newRow);
        rowIndex++;
        calculateTotal();
    }

    // Jalankan hitung total saat pertama kali buka
    document.addEventListener('DOMContentLoaded', calculateTotal);
    document.addEventListener('change', (e) => {
        if (e.target.name && e.target.name.includes('[layanan_id]')) calculateTotal();
    });
</script>

<%- include('partials/footer') %>
