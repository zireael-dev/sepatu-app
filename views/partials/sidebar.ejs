<div class="w-64 bg-slate-800 text-white flex flex-col h-screen shadow-xl">
    <div class="p-6 text-2xl font-bold border-b border-slate-700 flex items-center gap-2">
        <span class="text-blue-400">👟</span> Shoes Care
    </div>

    <nav class="flex-grow p-4 space-y-2">
        <a href="/dashboard" class="flex items-center space-x-3 py-2.5 px-4 rounded transition hover:bg-slate-700">
            <span>Dashboard</span>
        </a>
        <a href="/order" class="flex items-center space-x-3 py-2.5 px-4 rounded transition hover:bg-slate-700">
            <span>Buat Order Baru</span>
        </a>
        <a href="/pelanggan" class="flex items-center space-x-3 py-2.5 px-4 rounded transition hover:bg-slate-700">
            <span>Database Pelanggan</span>
        </a>
        <a href="/list-order" class="flex items-center space-x-3 py-2.5 px-4 rounded transition hover:bg-slate-700">
            <span>List Orderan</span>
        </a>

        <% if (user && user.role === 'owner') { %>
            <div class="pt-4 mt-4 border-t border-slate-700">
                <p class="px-4 text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Owner Area</p>
                <a href="/layanan" class="flex items-center space-x-3 py-2.5 px-4 rounded transition hover:bg-slate-700 text-green-400">
                    <span>⚙️ Database Layanan</span>
                </a>
                <a href="/laporan" class="flex items-center space-x-3 py-2.5 px-4 rounded transition hover:bg-slate-700 text-yellow-400">
                    <span>📊 Laporan Keuangan</span>
                </a>
            </div>
        <% } %>

    </nav>

    <div class="p-4 border-t border-slate-700 bg-slate-900">
        <div class="flex items-center justify-between">
            <div class="text-sm">
                <p class="text-slate-400 text-xs">Login sebagai:</p>
                <p class="font-semibold text-blue-300"><%= user.username %></p>
            </div>
            <a href="/logout" class="text-red-400 hover:text-red-300 text-sm font-bold">Keluar</a>
        </div>
    </div>
</div>
