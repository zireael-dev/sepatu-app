<%- include('partials/header') %>
<div class="max-w-md mx-auto bg-white min-h-screen shadow-lg p-6">
    <div class="text-center mb-8">
        <h1 class="text-2xl font-black text-blue-600">ShoesCare</h1>
        <p class="text-gray-500 text-xs">Nota Elektronik #ORD-<%= order.id %></p>
    </div>

    <div class="border-b-2 border-dashed border-gray-100 pb-4 mb-4">
        <p class="text-xs text-gray-400 uppercase font-bold">Pelanggan</p>
        <p class="font-bold text-gray-800"><%= order.nama %></p>
        <p class="text-sm text-gray-500"><%= order.whatsapp %></p>
    </div>

    <div class="space-y-4 mb-8">
        <% details.forEach(d => { %>
        <div class="flex justify-between items-center">
            <div>
                <p class="font-bold text-gray-700 text-sm">👟 <%= d.nama_sepatu %></p>
                <p class="text-xs text-blue-500"><%= d.nama_layanan %></p>
            </div>
            <p class="font-mono text-sm">Rp <%= d.harga_satuan.toLocaleString() %></p>
        </div>
        <% }) %>
    </div>

    <div class="bg-blue-50 p-4 rounded-xl flex justify-between items-center mb-8">
        <span class="font-bold text-blue-800 text-sm">TOTAL TAGIHAN</span>
        <span class="text-xl font-black text-blue-600">Rp <%= order.total_harga.toLocaleString() %></span>
    </div>

    <div class="text-center">
        <div class="inline-block px-6 py-2 rounded-full font-bold text-sm <%= order.status === 'Selesai' ? 'bg-green-100 text-green-700' : 'bg-orange-100 text-orange-700 animate-pulse' %>">
            Status: <%= order.status %>
        </div>
        <p class="text-[10px] text-gray-400 mt-6">Terima kasih telah mempercayakan sepatu Anda kepada kami.</p>
    </div>
</div>
<%- include('partials/footer') %>
